-- Active: 1782706749849@@aws-1-us-east-1.pooler.supabase.com@5432@postgres

# ══════════════════════════════════════════════════════════════════════════════
# Avril-RAG v2.0 — Configuración de LLM y Embeddings
# ══════════════════════════════════════════════════════════════════════════════
# Copia este archivo a .env y ajusta los valores según tu configuración
# ══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# 🤖 CONFIGURACIÓN DEL LLM (distilador.py)
# ─────────────────────────────────────────────────────────────────────────────

# Proveedor LLM: nvidia | openai | gemini | custom
LLM_PROVIDER=gemini

# Modelo específico (depende del proveedor)
# NVIDIA: meta/llama-3.1-70b-instruct, meta/llama-3.1-405b-instruct, etc.
# OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo, etc.
# Gemini: gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash, etc.
# Groq: llama-3.3-70b-versatile

LLM_MODEL=gemini-2.0-flash

# API Keys según el proveedor
# NVIDIA_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# GROQ_API_KEY=

# (Opcional) Para provider=custom
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_API_KEY=tu_clave_custom

# ─────────────────────────────────────────────────────────────────────────────
# 🧠 CONFIGURACIÓN DE EMBEDDINGS (supabase_client.py)
# ─────────────────────────────────────────────────────────────────────────────

# Proveedor de embeddings: nvidia | openai | custom
EMBEDDINGS_PROVIDER=nvidia

# Modelo de embeddings
# NVIDIA: nvidia/nv-embedqa-e5-v5 (1024 dims, comercial)
# OpenAI: text-embedding-3-small (1536 dims), text-embedding-3-large (3072 dims)
EMBEDDINGS_MODEL=nvidia/nv-embedqa-e5-v5

# Número de dimensiones del modelo
# nvidia/nv-embedqa-e5-v5: 1024
# text-embedding-3-small: 1536
# text-embedding-3-large: 3072
EMBEDDINGS_DIMENSIONS=1024

# (Opcional) Para provider=custom
# EMBEDDINGS_URL=https://custom-api.com/v1/embeddings
# EMBEDDINGS_API_KEY=tu_clave_custom

# ─────────────────────────────────────────────────────────────────────────────
# 💾 CONFIGURACIÓN DE BASE DE DATOS (supabase_client.py)
# ─────────────────────────────────────────────────────────────────────────────

SUPABASE_KEY= 
SUPABASE_CONN= 

# ─────────────────────────────────────────────────────────────────────────────
# 🌐 CONFIGURACIÓN DE SPIDERS
# ─────────────────────────────────────────────────────────────────────────────

PRODUCTHUNT_TOKEN= 

# ─────────────────────────────────────────────────────────────────────────────
# 🔧 CONFIGURACIÓN PYTHON
# ─────────────────────────────────────────────────────────────────────────────

PYTHONUNBUFFERED=1

# ══════════════════════════════════════════════════════════════════════════════
# 📋 PERFILES PRE-CONFIGURADOS
# ══════════════════════════════════════════════════════════════════════════════

# PERFIL 1: Desarrollo rápido (NVIDIA para todo) - RECOMENDADO
# Descomenta estas líneas si quieres usar NVIDIA para LLM y embeddings:
#
# LLM_PROVIDER=nvidia
# LLM_MODEL=meta/llama-3.1-70b-instruct
# NVIDIA_API_KEY=tu_clave_nvidia
# EMBEDDINGS_PROVIDER=nvidia
# EMBEDDINGS_MODEL=nvidia/nv-embedqa-e5-v5
# EMBEDDINGS_DIMENSIONS=1024

# ─────────────────────────────────────────────────────────────────────────────

# PERFIL 2: Producción OpenAI (máxima calidad)
# Descomenta estas líneas para usar OpenAI para todo:
#
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4-turbo
# OPENAI_API_KEY=sk-proj-...
# EMBEDDINGS_PROVIDER=openai
# EMBEDDINGS_MODEL=text-embedding-3-large
# EMBEDDINGS_DIMENSIONS=3072

# ─────────────────────────────────────────────────────────────────────────────

# PERFIL 3: Híbrido (NVIDIA LLM + OpenAI embeddings)
# Descomenta estas líneas para máxima calidad de embeddings:
#
# LLM_PROVIDER=nvidia
# LLM_MODEL=meta/llama-3.1-70b-instruct
# NVIDIA_API_KEY=tu_clave_nvidia
# EMBEDDINGS_PROVIDER=openai
# EMBEDDINGS_MODEL=text-embedding-3-large
# EMBEDDINGS_DIMENSIONS=3072
# OPENAI_API_KEY=sk-proj-...

# ──────────────────────────────────────────────────────────────────────────────

# PERFIL 4: Local (LLM local con embeddings OpenAI)
# Descomenta estas líneas para ejecutar LLM localmente (ej. Ollama):
#
# LLM_PROVIDER=custom
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=local
# LLM_MODEL=llama2:70b-chat-q4_K_M
# EMBEDDINGS_PROVIDER=openai
# EMBEDDINGS_MODEL=text-embedding-3-small
# EMBEDDINGS_DIMENSIONS=1536
# OPENAI_API_KEY=sk-proj-...

# ──────────────────────────────────────────────────────────────────────────────

# PERFIL 5: Google Gemini (RECOMENDADO - Gratis hasta 1500 requests/día)
# Descomenta estas líneas para usar Google Gemini:
#
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.0-flash  # O gemini-1.5-pro, gemini-1.5-flash
# GOOGLE_API_KEY=AIzaSy...    # Obtén en https://ai.google.dev/
# EMBEDDINGS_PROVIDER=openai  # Usa OpenAI para embeddings de mejor calidad
# EMBEDDINGS_MODEL=text-embedding-3-small
# EMBEDDINGS_DIMENSIONS=1536
# OPENAI_API_KEY=sk-proj-...

# ══════════════════════════════════════════════════════════════════════════════

